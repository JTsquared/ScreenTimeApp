# Cloud Backend Configuration
BACKEND_URL=http://your-cloud-server-ip:3000
PI_SERVICE_API_KEY=your-raspberry-pi-api-key-change-this

# Pi-hole Configuration (v6)
PIHOLE_URL=https://localhost
PIHOLE_PASSWORD=your-pihole-admin-password

# Polling Configuration
COMMAND_POLL_INTERVAL=5000
SESSION_CHECK_INTERVAL=60000

# Logging
LOG_LEVEL=info
