{
  "expo": {
    "name": "ScreenTime Manager",
    "slug": "screentime-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6200ee"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.screentime.manager"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6200ee"
      },
      "package": "com.screentime.manager"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "ScreenTime Manager",
      "shortName": "ScreenTime",
      "description": "Family chore and screen time management",
      "backgroundColor": "#6200ee",
      "themeColor": "#6200ee",
      "display": "standalone",
      "startUrl": "/"
    },
    "scheme": "screentime",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
